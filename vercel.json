{
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" },
    { "src": "src/server/proxy.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "src/server/proxy.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}